document.addEventListener('DOMContentLoaded', () => {
    const videoPlayer = document.getElementById('videoPlayer');
    const movieGrid = document.getElementById('movie-grid');

    // --- 1. Функция получения данных (имитация API вызова) ---
    async function fetchMovies(query = 'action') {
        console.log(`Загрузка фильмов по запросу: ${query}...`);

        // В реальной жизни здесь будет fetch() к вашему бэкенду,
        // который, в свою очередь, обратится к YouTube API.

        // Имитация ответа (массив объектов)
        return [
            { title: "Начало (Inception)", videoId: "9XYz123ABC", thumbnail:
"https://via.placeholder.com/300x150?text=Inception" },
            { title: "Темный рыцарь", videoId: "aBcD456EFG", thumbnail:
"https://via.placeholder.com/300x150?text=The+Dark+Knight" },
            { title: "Интерстеллар", videoId: "hIjK789LMN", thumbnail:
"https://via.placeholder.com/300x150?text=Interstellar" }
        ];
    }

    // --- 2. Функция отрисовки карточек ---
    function renderMovies(movies) {
        movieGrid.innerHTML = ''; // Очищаем старые карточки
        movies.forEach(movie => {
            const card = document.createElement('div');
            card.classList.add('movie-card');
            card.innerHTML = `
                <img src="${movie.thumbnail}" alt="${movie.title} постер">
                <h3>${movie.title}</h3>
                <p>Нажмите, чтобы посмотреть</p>
            `;
            card.addEventListener('click', () => {
                playMovie(movie.videoId, movie.title);
            });
            movieGrid.appendChild(card);
        });
    }

    // --- 3. Функция управления плеером ---
    function playMovie(videoId, title) {
        // Устанавливаем источник видео (YouTube ID)
        const videoUrl = `https://www.youtube.com/embed/${videoId}`;
        videoPlayer.src = videoUrl;

        // Меняем заголовок, чтобы пользователь знал, что играет
        document.querySelector('#player-container h2').textContent = `Просмотр: ${title}`;

        // Важно: Если вы используете iframe для YouTube, нужно менять src iframe.
        // Если вы просто используете тег <video>, то этот метод сработает.
    }

    // --- Инициализация ---
    async function init() {
        try {
            const movies = await fetchMovies();
            renderMovies(movies);

            // Загружаем первый фильм по умолчанию
            if (movies.length > 0) {
                playMovie(movies[0].videoId, movies[0].title);
            }
        } catch (error) {
            console.error("Ошибка при инициализации плеера:", error);
            document.getElementById('movie-grid').innerHTML = '<p style="color: red;">Не удалось загрузить фильмы.
Проверьте API ключ или соединение.</p>';
        }
    }

    init();
});
